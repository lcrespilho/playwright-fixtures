{
  "compilerOptions": {
    /* Padrões Modernos */
    "target": "ES2025", // TS 6.0 recomenda targets datados ou ESNext
    "module": "NodeNext",
    "moduleResolution": "NodeNext", // Agora obrigatório ser explícito com NodeNext

    /* Configurações de Emissão */
    "outDir": "./dist",
    "sourceMap": true,
    "declaration": true,
    "rootDir": "./src",
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
